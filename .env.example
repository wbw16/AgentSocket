# LLM 提供商选择: anthropic | openai (默认: anthropic)
LLM_PROVIDER=anthropic

# 模型名称 (不设则使用各 provider 默认值)
# Anthropic 默认: claude-opus-4-7
# OpenAI 默认: gpt-4o
AGENT_MODEL=claude-opus-4-7

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # 可选，自定义端点

# OpenAI 及兼容接口 (DeepSeek / vLLM / Ollama 等)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1     # 可选，指向兼容接口
